{
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-opus-4-1"
      }
    }
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  },

  "server": {
    "host": "0.0.0.0",
    "port": 8080
  }
}