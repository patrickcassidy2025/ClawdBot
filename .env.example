# Core
OPENCLAW_HOST=0.0.0.0
OPENCLAW_PORT=8080
CLAWDBOT_ENV=production
CLAWDBOT_LOG_LEVEL=info
CLAWDBOT_WORKSPACE=./workspace

# Telegram
TELEGRAM_BOT_TOKEN=replace_me

# Anthropic / Claude
ANTHROPIC_API_KEY=replace_me

# OpenAI (Whisper transcription for voice messages)
OPENAI_API_KEY=replace_me

# GitHub (PR review, open PRs in daily briefing, webhook notifications)
GITHUB_TOKEN=replace_me
# Comma-separated list of repos for the daily briefing (preferred).
GITHUB_REPOS=patrickcassidy2025/ClawdBot,Presight-AI/vantage-backend,Presight-AI/vantage-frontend
# Legacy single-repo var, kept for backward compatibility (used only if GITHUB_REPOS is unset).
GITHUB_REPO=patrickcassidy2025/ClawdBot
GITHUB_WEBHOOK_SECRET=replace_me

# Telegram notifications (daily briefing + GitHub webhook alerts)
TELEGRAM_NOTIFY_CHAT_ID=replace_me

# Weather location for daily briefing (optional — defaults to server's IP location)
WEATHER_LOCATION=

# Optional
OPENCLAW_CONFIG=./config/openclaw.jsonc